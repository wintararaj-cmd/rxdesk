# Maddy Mail Server Configuration
MADDY_HOSTNAME=mx.rxdesk.in
MADDY_DOMAIN=rxdesk.in

# Webmail Port (changed from 8000 to avoid conflict with Coolify)
ALPS_PORT=8081

# To manage users, use the Maddy CLI:
# docker exec -it mail_maddy maddyctl -c /data/maddy.conf creds create user@docnear.com
# docker exec -it mail_maddy maddyctl -c /data/maddy.conf imap-accts create user@docnear.com

# Session encryption key for Alps
ALPS_LOGIN_KEY=changeme_secret_random_string
