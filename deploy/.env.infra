# Docker Compose infrastructure .env
# Place this file alongside docker-compose.prod.yml as  deploy/.env
# (Docker Compose automatically reads .env from the same directory)

POSTGRES_DB=rxdesk_prod
POSTGRES_USER=rxdesk
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Must match the password in DATABASE_URL / REDIS_URL in .env.backend.prod
# Generate with: openssl rand -hex 16
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
