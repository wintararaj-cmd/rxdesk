{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@rxdesk/shared": [
        "../../packages/shared/src"
      ],
      "@react-native/virtualized-lists": [
        "../../node_modules/@react-native/virtualized-lists"
      ],
      "react-native": [
        "node_modules/react-native"
      ],
      "react-native/*": [
        "node_modules/react-native/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
