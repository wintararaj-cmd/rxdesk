# ─── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://rxdesk:secret@localhost:5432/rxdesk_dev"

# ─── Redis ───────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Set to true in development when a real Redis server is not running locally
USE_REDIS_MOCK=false

# ─── JWT ─────────────────────────────────────────────────
# Use strong random secrets in production (min 32 chars)
JWT_ACCESS_SECRET="replace-with-strong-secret-min-32-characters"
JWT_REFRESH_SECRET="replace-with-different-strong-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── File Storage (AWS S3 / Cloudflare R2 / Backblaze B2) ───────────────────
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_REGION="ap-south-1"
S3_BUCKET_NAME="rxdesk-files-dev"
# For Cloudflare R2: set endpoint + change region to "auto"
# S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# For Backblaze B2: set endpoint + use your bucket region
# S3_ENDPOINT="https://s3.us-west-004.backblazeb2.com"

# ─── MSG91 SMS (OTP + Notifications) ─────────────────────
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_TEMPLATE_ID_OTP="your-otp-template-id"
MSG91_TEMPLATE_ID_REMINDER="your-reminder-template-id"
MSG91_SENDER_ID="DOCNER"

# ─── Firebase (Push Notifications) ───────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"rxdesk","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}'

# ─── Razorpay ────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# ─── Google Maps ─────────────────────────────────────────
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── Prescription QR Signing ─────────────────────────────
PRESCRIPTION_HMAC_SECRET="replace-with-strong-prescription-signing-secret"

# ─── App URLs ────────────────────────────────────────────
FRONTEND_URL="http://localhost:3001"
API_URL="http://localhost:3000"

# ─── OTP Settings ────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
# In development, set a fixed OTP to skip SMS
DEV_FIXED_OTP="123456"
